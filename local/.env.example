# IB Gateway connection
IB_GATEWAY_HOST=127.0.0.1
IB_GATEWAY_PORT=4001          # live: 4001 | paper: 4002
IB_CLIENT_ID=10               # must be unique; not used by TWS or other sessions
IB_ACCOUNT_ID=U9376705        # your IB account number

# Cloud endpoint
CLOUD_API_URL=https://your-app.fly.dev/api/positions
CLOUD_API_KEY=your-positions-api-key-here
ACCOUNT_KEY=ALICE             # matches ACCOUNT_ALICE_* env vars on cloud
