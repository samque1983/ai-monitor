# Copy to .env and fill in values
# cp .env.example .env

# ── IB Gateway (Paper account) ────────────────────────────────────────────
IB_TWS_USERID=your_ib_username
IB_TWS_PASSWORD=your_ib_password

# ── Agent API ─────────────────────────────────────────────────────────────
SCAN_API_KEY=your_scan_api_key          # shared secret between radar and agent
ANTHROPIC_API_KEY=sk-ant-xxx            # for Claude card engine (optional)

# ── Notifications (optional) ──────────────────────────────────────────────
DINGTALK_WEBHOOK=
DINGTALK_APP_SECRET=

# ── Market data fallback ──────────────────────────────────────────────────
POLYGON_API_KEY=                        # fallback if IB Gateway unavailable
TRADIER_API_KEY=                        # options chain fallback

# ── Portfolio Risk Report ──────────────────────────────────────────────
# Flex Web Service credentials (IBKR Reports → Flex Queries)
ACCOUNT_ALICE_NAME=My IB Account
ACCOUNT_ALICE_FLEX_TOKEN=              # Flex Web Service token
ACCOUNT_ALICE_FLEX_QUERY_ID=           # Flex Query ID

# LLM for AI suggestions (DeepSeek preferred, falls back to Anthropic)
DEEPSEEK_API_KEY=sk-xxx

# Account financials — update weekly from TWS Portfolio page
# Flex does not provide these; needed for margin/cushion alerts
ACCOUNT_ALICE_NLV=                     # Net Liquidation Value, e.g. 500000
ACCOUNT_ALICE_CUSHION=                 # Cushion as decimal, e.g. 0.32
ACCOUNT_ALICE_MAINT_MARGIN=            # Maintenance Margin Req, e.g. 85000
