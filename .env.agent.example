# LLM Provider (new style — pick one block)
# --- Option A: DeepSeek ---
LLM_PROVIDER=deepseek
LLM_API_KEY=your_deepseek_api_key
LLM_MODEL=deepseek-chat

# --- Option B: OpenAI ---
# LLM_PROVIDER=openai
# LLM_API_KEY=your_openai_api_key
# LLM_MODEL=gpt-4o

# --- Option C: Anthropic (also works via legacy var below) ---
# LLM_PROVIDER=anthropic
# LLM_API_KEY=sk-ant-xxx

# Legacy — still works for Anthropic (auto-detected if LLM_PROVIDER not set)
# ANTHROPIC_API_KEY=sk-ant-xxx
# CLAUDE_MODEL=claude-opus-4-6

DINGTALK_APP_SECRET=your_dingtalk_app_secret
SCAN_API_KEY=generate_a_random_key_here
AGENT_DB_PATH=/data/agent.db
